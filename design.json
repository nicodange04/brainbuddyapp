{
    "designSystem": {
      "name": "Educational Dashboard Design System",
      "version": "1.0.0",
      "description": "A modern, friendly educational platform design system with rounded corners, soft shadows, and playful illustrations",
      
      "colorPalette": {
        "primary": {
          "violet": "#8B5CF6",
          "violetLight": "#A78BFA",
          "violetDark": "#7C3AED"
        },
        "secondary": {
          "white": "#FFFFFF",
          "offWhite": "#F9FAFB"
        },
        "accent": {
          "orange": "#FB923C",
          "orangeLight": "#FDBA74",
          "peach": "#FED7AA",
          "coral": "#FCA5A5"
        },
        "neutral": {
          "black": "#1F2937",
          "darkGray": "#374151",
          "mediumGray": "#6B7280",
          "lightGray": "#E5E7EB",
          "backgroundBeige": "#FFEFD5"
        },
        "supporting": {
          "blue": "#60A5FA",
          "blueLight": "#93C5FD",
          "yellow": "#FCD34D",
          "green": "#34D399",
          "pink": "#F472B6"
        }
      },
  
      "typography": {
        "fontFamilies": {
          "primary": "system-ui, -apple-system, 'Segoe UI', sans-serif",
          "display": "'SF Pro Display', 'Helvetica Neue', sans-serif"
        },
        "fontSizes": {
          "xs": "0.75rem",
          "sm": "0.875rem",
          "base": "1rem",
          "lg": "1.125rem",
          "xl": "1.25rem",
          "2xl": "1.5rem",
          "3xl": "1.875rem",
          "4xl": "2.25rem",
          "5xl": "3rem"
        },
        "fontWeights": {
          "normal": 400,
          "medium": 500,
          "semibold": 600,
          "bold": 700,
          "extrabold": 800
        },
        "headingStyles": {
          "h1": {
            "fontSize": "3xl",
            "fontWeight": "extrabold",
            "color": "neutral.black"
          },
          "h2": {
            "fontSize": "2xl",
            "fontWeight": "bold",
            "color": "neutral.black"
          },
          "h3": {
            "fontSize": "xl",
            "fontWeight": "semibold",
            "color": "neutral.black"
          },
          "subtitle": {
            "fontSize": "sm",
            "fontWeight": "medium",
            "color": "neutral.mediumGray"
          }
        }
      },
  
      "spacing": {
        "scale": "4px base (Tailwind-like)",
        "values": {
          "xs": "0.25rem",
          "sm": "0.5rem",
          "md": "1rem",
          "lg": "1.5rem",
          "xl": "2rem",
          "2xl": "2.5rem",
          "3xl": "3rem"
        }
      },
  
      "borderRadius": {
        "sm": "0.375rem",
        "md": "0.5rem",
        "lg": "0.75rem",
        "xl": "1rem",
        "2xl": "1.5rem",
        "3xl": "2rem",
        "full": "9999px",
        "card": "1.5rem",
        "button": "9999px"
      },
  
      "shadows": {
        "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "base": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
        "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
        "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
        "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
        "soft": "0 8px 24px rgba(139, 92, 246, 0.12)"
      },
  
      "components": {
        "card": {
          "variants": {
            "default": {
              "backgroundColor": "white",
              "borderRadius": "card",
              "padding": "lg to xl",
              "shadow": "soft",
              "border": "none"
            },
            "hero": {
              "backgroundColor": "gradient or solid color",
              "borderRadius": "card",
              "padding": "xl to 2xl",
              "minHeight": "200px",
              "position": "relative",
              "overflow": "hidden"
            },
            "stat": {
              "backgroundColor": "white or tinted",
              "borderRadius": "xl",
              "padding": "lg",
              "border": "2px solid lightGray or accent",
              "textAlign": "center"
            },
            "compact": {
              "backgroundColor": "white",
              "borderRadius": "lg",
              "padding": "md",
              "shadow": "base"
            }
          },
          "decorativeElements": {
            "icons": "Floating decorative icons (stars, geometric shapes, abstract shapes)",
            "illustrations": "Playful, simplified illustrations with bold outlines",
            "patterns": "Dotted backgrounds, subtle gradients, organic shapes",
            "positioning": "Absolute positioned decorative elements scattered naturally"
          }
        },
  
        "button": {
          "variants": {
            "primary": {
              "backgroundColor": "primary.violet",
              "color": "white",
              "borderRadius": "button",
              "padding": "0.75rem 1.5rem",
              "fontWeight": "semibold",
              "shadow": "md",
              "hover": "scale(1.02) + darker shade"
            },
            "secondary": {
              "backgroundColor": "neutral.black",
              "color": "white",
              "borderRadius": "button",
              "padding": "0.75rem 1.5rem",
              "fontWeight": "semibold"
            },
            "icon": {
              "backgroundColor": "white or black",
              "color": "contrasting color",
              "borderRadius": "full",
              "padding": "1rem",
              "size": "48px to 64px",
              "shadow": "base",
              "display": "flex items center justify center"
            },
            "pill": {
              "backgroundColor": "black or dark",
              "color": "white",
              "borderRadius": "full",
              "padding": "0.5rem 1.25rem",
              "fontSize": "sm",
              "fontWeight": "medium",
              "display": "inline-flex items-center gap-2"
            }
          }
        },
  
        "badge": {
          "variants": {
            "stat": {
              "display": "inline-flex items-center gap-2",
              "padding": "0.5rem 1rem",
              "borderRadius": "full",
              "backgroundColor": "black or accent",
              "color": "white",
              "fontSize": "sm",
              "fontWeight": "medium"
            },
            "icon": {
              "size": "40px to 56px",
              "borderRadius": "full",
              "backgroundColor": "accent color",
              "display": "flex items center justify center",
              "iconSize": "20px to 24px"
            }
          }
        },
  
        "avatar": {
          "sizes": {
            "sm": "32px",
            "md": "48px",
            "lg": "64px"
          },
          "style": {
            "borderRadius": "full",
            "border": "2px solid white (for overlap)",
            "overflow": "hidden"
          },
          "group": {
            "overlap": "-8px to -12px margin-left",
            "zIndex": "stack in reverse order",
            "maxVisible": "3-4 avatars",
            "plusBadge": "Show '+N' for additional users"
          }
        },
  
        "chart": {
          "barChart": {
            "type": "Vertical bar chart with rounded tops",
            "barRadius": "top corners rounded (8px)",
            "gap": "8px to 12px",
            "colors": "Use accent colors (orange, coral, neutral)",
            "labels": "Below bars, small font",
            "values": "Inside or above bars in white or contrasting color",
            "height": "Varies by value (animated growth)"
          },
          "progressBar": {
            "height": "8px to 12px",
            "borderRadius": "full",
            "backgroundColor": "lightGray",
            "fill": "gradient or solid accent color",
            "segments": "Multiple colored segments for comparison",
            "labels": "Below with month/period and lesson count"
          }
        },
  
        "navigationBar": {
          "position": "fixed bottom",
          "style": {
            "backgroundColor": "neutral.black",
            "borderRadius": "3xl",
            "padding": "1rem 1.5rem",
            "margin": "1rem",
            "shadow": "xl",
            "display": "flex items center justify around",
            "maxWidth": "400px"
          },
          "items": {
            "icon": "24px to 28px",
            "activeState": {
              "backgroundColor": "primary.violet",
              "borderRadius": "full",
              "padding": "0.75rem",
              "scale": "1.1"
            },
            "inactiveState": {
              "color": "mediumGray",
              "opacity": "0.6"
            }
          }
        },
  
        "header": {
          "userGreeting": {
            "display": "flex items-center gap-3",
            "avatar": "md to lg size",
            "text": {
              "greeting": "h2 or h3 style",
              "subtitle": "small, with icon (lightning bolt for progress)"
            }
          },
          "notifications": {
            "type": "icon button",
            "badge": "red dot for unread",
            "position": "top right"
          }
        },
  
        "statDisplay": {
          "layout": "2-column grid or horizontal flex",
          "cards": {
            "borderRadius": "xl",
            "padding": "lg to xl",
            "border": "2px solid (optional)",
            "icon": "top or left side",
            "label": "small, uppercase or normal case",
            "value": "3xl to 4xl, bold",
            "colors": "Alternate between accent colors"
          }
        },
  
        "courseCard": {
          "style": {
            "borderRadius": "2xl",
            "overflow": "hidden",
            "backgroundColor": "dark or accent gradient",
            "minHeight": "150px to 200px",
            "position": "relative"
          },
          "content": {
            "badge": "top left with icon",
            "title": "bold, white text",
            "subtitle": "smaller, semi-transparent white",
            "participants": "avatar group",
            "action": "circular button bottom right"
          },
          "decorativeElements": "Abstract shapes, icons as background"
        },
  
        "toggleGroup": {
          "container": {
            "display": "inline-flex",
            "backgroundColor": "lightGray or offWhite",
            "borderRadius": "full",
            "padding": "0.25rem"
          },
          "button": {
            "borderRadius": "full",
            "padding": "0.5rem 1.25rem",
            "fontWeight": "medium",
            "transition": "all 200ms",
            "active": {
              "backgroundColor": "black or violet",
              "color": "white"
            },
            "inactive": {
              "backgroundColor": "transparent",
              "color": "mediumGray"
            }
          }
        },
  
        "dropdown": {
          "trigger": {
            "display": "inline-flex items-center gap-2",
            "padding": "0.5rem 1rem",
            "borderRadius": "full",
            "backgroundColor": "lightGray",
            "fontSize": "sm",
            "fontWeight": "medium",
            "icon": "chevron or arrow"
          }
        },
  
        "iconButton": {
          "moreOptions": {
            "borderRadius": "full",
            "padding": "0.5rem",
            "backgroundColor": "transparent or white",
            "hover": "backgroundColor change",
            "icon": "three dots horizontal"
          }
        }
      },
  
      "layouts": {
        "mobileFirst": true,
        "maxWidth": "400px to 450px per screen",
        "padding": "1rem to 1.5rem",
        "gap": "1rem to 1.5rem between sections",
        "grid": {
          "columns": "1 or 2 columns max on mobile",
          "gap": "1rem"
        },
        "sections": {
          "header": "sticky top, padding bottom",
          "heroSection": "full width, prominent placement",
          "statsGrid": "2-column grid",
          "contentCards": "vertical stack with gap",
          "navigation": "fixed bottom"
        }
      },
  
      "animations": {
        "transitions": {
          "default": "200ms ease-in-out",
          "slow": "300ms ease-in-out",
          "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
        },
        "hover": {
          "scale": "1.02 to 1.05",
          "shadow": "increase shadow",
          "brightness": "slight increase"
        },
        "active": {
          "scale": "0.98",
          "transition": "100ms"
        },
        "entrance": {
          "fadeIn": "opacity 0 to 1",
          "slideUp": "translateY(20px) to 0",
          "stagger": "50ms to 100ms delay between items"
        }
      },
  
      "illustrations": {
        "style": "Modern, flat, geometric with soft shadows",
        "characteristics": [
          "Bold outlines (2-3px)",
          "Soft gradients within shapes",
          "Layered composition (3D effect)",
          "Rounded corners on all shapes",
          "Playful proportions",
          "Minimal detail, maximum clarity"
        ],
        "commonElements": [
          "Graduation caps",
          "Books and notebooks",
          "Stars and sparkles",
          "Geometric shapes (triangles, circles, squares)",
          "Abstract blobs and curves",
          "Trophy and achievement icons",
          "Lightning bolts",
          "Abstract 3D shapes"
        ],
        "placement": "Scattered as background decoration or focal point in hero cards",
        "colorUsage": "Use brand colors (violet, orange, blue) with white highlights"
      },
  
      "iconography": {
        "style": "Line icons or filled icons",
        "weight": "regular to medium (1.5px to 2px)",
        "sizes": {
          "sm": "16px",
          "md": "20px to 24px",
          "lg": "28px to 32px"
        },
        "usage": [
          "Navigation items",
          "Stat labels",
          "Decorative elements",
          "Action buttons",
          "Subject identifiers"
        ]
      },
  
      "accessibilityGuidelines": {
        "contrast": "WCAG AA minimum (4.5:1 for text)",
        "focusStates": "Visible outline or ring on focus",
        "touchTargets": "Minimum 44px x 44px",
        "textSize": "Minimum 14px for body text",
        "colorBlindness": "Don't rely solely on color for information"
      },
  
      "designPrinciples": [
        "Friendly and approachable - use rounded corners everywhere",
        "Playful but professional - balance fun illustrations with clean layouts",
        "Clear hierarchy - use size, weight, and color to guide attention",
        "Consistent spacing - maintain rhythm throughout",
        "Generous whitespace - don't overcrowd",
        "Mobile-optimized - design for touch interactions",
        "Delightful interactions - subtle animations and transitions",
        "Accessible - ensure everyone can use the interface"
      ],
  
      "usageNotes": {
        "cards": "Always use soft shadows and generous border radius",
        "colors": "Violet for primary actions and branding, white for backgrounds, orange/coral for accents and highlights",
        "typography": "Bold headlines, medium weight for body, don't mix too many weights",
        "spacing": "Use consistent spacing scale (multiples of 4px or 8px)",
        "illustrations": "Keep decorative, not informational. Should enhance but not distract",
        "darkMode": "Black (#1F2937) for dark elements, not pure black",
        "buttons": "Pill-shaped for primary actions, circular for icon-only",
        "data visualization": "Use rounded bar charts, clear labels, accent colors"
      }
    }
  }